REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:5173"]
VITE_API_BASE_URL=http://localhost:8000

# Google Calendar sync (optional): leave blank to run against the in-process
# fake Google adapter (no real network calls). Fill in with an OAuth 2.0
# "Web application" Client ID/Secret from Google Cloud Console (Calendar API
# enabled) to sync for real. Put the real values in a root .env, never here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
